---
import '../styles/global.css';

const news = [
  {
    date: '2026',
    title: 'Speech Prosody 2026 — Show and Tell',
    description: 'Articulatory.Tech will present at the Show and Tell session at Speech Prosody 2026. Details to be announced.',
    tag: 'Conference',
  },
];
---

<section id="news" class="py-16 sm:py-20 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-8">News</h2>
    <ul class="list-none m-0 p-0 flex flex-col gap-6">
      {news.map((item) => (
        <li class="border-l-2 border-brand-blue pl-6 py-1">
          <div class="flex items-center gap-3 mb-1">
            <span class="text-xs font-medium text-brand-blue bg-brand-blue/10 px-2 py-0.5 rounded">{item.tag}</span>
            <span class="text-sm text-gray-400">{item.date}</span>
          </div>
          <h3 class="text-base sm:text-lg font-semibold text-navy mb-1">{item.title}</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">{item.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
