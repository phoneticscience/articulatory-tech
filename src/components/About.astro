---
import '../styles/global.css';
---

<section id="about" class="py-16 sm:py-20 px-6">
  <div class="max-w-xl sm:max-w-2xl md:max-w-3xl mx-auto text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-6">About</h2>
    <p class="text-gray-600 leading-relaxed mb-4 text-sm sm:text-base">
      Founded by Jaekoo Kang, PhD (Speech Science, CUNY Graduate Center).
      Research background in articulatory phonology, with professional experience
      in speech data analysis, signal processing, and deep learning applied to speech.
    </p>
    <a
      href="https://jaekookang.me"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block text-brand-blue hover:text-brand-blue-dark font-medium no-underline transition-colors text-sm sm:text-base"
    >
      jaekookang.me
    </a>
  </div>
</section>
